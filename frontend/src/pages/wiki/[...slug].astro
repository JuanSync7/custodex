---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ConsoleChrome from "../../components/ConsoleChrome.astro";

// EPIC ASTRO: native-Astro rendering of the EPIC-R wikis, inside the SAME console
// chrome as the main app (left instrument rail + topbar via ConsoleChrome). Each
// `feature-doc/` markdown doc is a static `/wiki/*` page; the four sections are a
// tab bar in the canvas. No render_markdown, no dangerouslySetInnerHTML.

interface SectionMeta {
  slug: string;
  title: string;
  order: number;
}

export async function getStaticPaths() {
  // `metaFor` lives INSIDE getStaticPaths: Astro hoists getStaticPaths into its
  // own scope, so it cannot see frontmatter-level helpers. Map an entry id ->
  // slug/title by substring (robust to the glob loader's id casing).
  function metaFor(id: string): SectionMeta | null {
    const u = id.toUpperCase();
    if (u.includes("TRACEABILITY"))
      return { slug: "traceability", title: "Traceability Matrix", order: 1 };
    if (u.includes("TEST")) return { slug: "tests", title: "Test Wiki", order: 2 };
    if (u.includes("SOURCE"))
      return { slug: "source", title: "Source Wiki", order: 3 };
    if (u.includes("FEATURES"))
      return { slug: "features", title: "Feature Reference", order: 0 };
    return null;
  }
  const entries = await getCollection("wiki");
  const known = entries
    .map((entry) => ({ entry, meta: metaFor(entry.id) }))
    .filter((x): x is { entry: (typeof entries)[number]; meta: SectionMeta } =>
      Boolean(x.meta),
    );
  const sections = known
    .map(({ meta }) => meta)
    .sort((a, b) => a.order - b.order);
  return known.map(({ entry, meta }) => ({
    params: { slug: meta.slug },
    props: { entry, meta, sections },
  }));
}

const { entry, meta, sections } = Astro.props;
const { Content } = await render(entry);
const href = (s: SectionMeta) => `/wiki/${s.slug}`;
---

<Layout title={`${meta.title} · code-doc-monitor wiki`}>
  <ConsoleChrome active="wiki" crumb={`Wiki · ${meta.title}`}>
    <nav class="wikitabs" aria-label="Wiki sections">
      {
        sections.map((s) => (
          <a
            class:list={["wikitab", { "wikitab--active": s.slug === meta.slug }]}
            href={href(s)}
            aria-current={s.slug === meta.slug ? "page" : undefined}
          >
            {s.title}
          </a>
        ))
      }
    </nav>
    <article class="prose wiki-body">
      <Content />
    </article>
  </ConsoleChrome>
</Layout>

<style>
  .wikitabs {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    margin: -0.6rem 0 1.8rem;
    border-bottom: 1px solid var(--line);
  }
  .wikitab {
    padding: 0.55rem 0.9rem;
    margin-bottom: -1px;
    border-radius: 8px 8px 0 0;
    border-bottom: 2px solid transparent;
    color: var(--text-dim);
    font-weight: 500;
    font-size: 0.92rem;
  }
  .wikitab:hover {
    text-decoration: none;
    background: var(--surface-2);
    color: var(--text);
  }
  .wikitab--active {
    color: var(--primary-strong);
    border-bottom-color: var(--primary);
    font-weight: 600;
  }
  .wiki-body {
    margin-top: 0.5rem;
  }
</style>
