---
// The document shell for the whole frontend (EPIC ASTRO). Shares the console's
// "Signal (dark)" design language (Linear/Vercel-style: near-black canvas,
// indigo→violet brand accent, Geist type) so the native wiki pages look
// identical to the main console — one dark, minimal surface.
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "code-doc-monitor",
  description = "Documentation drift, watched. The code-doc-monitor console.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        --font-display: "Geist", system-ui, -apple-system, sans-serif;
        --font-sans: "Geist", system-ui, -apple-system, sans-serif;
        --font-mono: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;

        /* "Signal (dark)" surfaces — match the console's index.css. */
        --bg: #08090a;
        --surface: #0e0f12;
        --surface-2: #16181d;
        --surface-3: #20232a;
        --border: rgba(255, 255, 255, 0.08);
        --border-soft: rgba(255, 255, 255, 0.05);
        --text: #edeef2;
        --text-dim: #9ea0ab;
        --text-faint: #7e808c; /* kept in sync with console index.css */

        --accent: #8b8bf5;
        --accent-strong: #a5a5fb;
        --accent-tint: rgba(99, 99, 222, 0.16);

        --radius: 12px;
        --radius-sm: 8px;
        --shadow: 0 2px 6px rgba(0, 0, 0, 0.45), 0 16px 40px -16px rgba(0, 0, 0, 0.7);

        color-scheme: dark;
      }

      * {
        box-sizing: border-box;
      }
      html {
        -webkit-text-size-adjust: 100%;
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-sans);
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-display);
        font-weight: 700;
        letter-spacing: -0.018em;
        line-height: 1.15;
        margin: 0 0 0.4em;
        color: var(--text);
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      code,
      kbd,
      pre {
        font-family: var(--font-mono);
        font-size: 0.92em;
      }
      ::selection {
        background: var(--accent-tint);
        color: var(--text);
      }

      .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-faint);
      }

      /* Readable column for the native-Astro wiki/doc pages — dark, like the
         console: light ink on near-black, hairline borders, soft code blocks. */
      .prose {
        max-width: 78ch;
        color: var(--text);
      }
      .prose :where(p, li) {
        color: #c7c9d1;
      }
      .prose :where(h1, h2, h3) {
        scroll-margin-top: 5rem;
      }
      .prose a {
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .prose pre {
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 1rem 1.1rem;
        overflow-x: auto;
      }
      .prose :not(pre) > code {
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 0.12em 0.4em;
      }
      .prose table {
        border-collapse: collapse;
        width: 100%;
        font-size: 0.92rem;
      }
      .prose th,
      .prose td {
        border: 1px solid var(--border);
        padding: 0.5rem 0.7rem;
        text-align: left;
      }
      .prose th {
        background: var(--surface-2);
        font-family: var(--font-mono);
        font-weight: 600;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </body>
</html>
