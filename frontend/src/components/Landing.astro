---
// The static showcase landing for juansync.dev (PUBLIC_SHOWCASE build only,
// rendered by pages/index.astro). Full-width marketing page — no backend — that
// positions Custodex and routes to the live demo, the wikis, and the tutorial.
// Imports the console stylesheet purely for its design tokens (the :root vars).
import "../console/index.css";

const REPO = "https://github.com/JuanSync7/custodex";

const FEATURES = [
  {
    title: "Code ↔ doc drift",
    body: "Fingerprints a code surface and grades every managed doc against it — audience-aware, so a comment-only change never flags a user guide but does flag an eng guide.",
  },
  {
    title: "Doc ↔ doc consistency",
    body: "Tracks references between documents too, so the whole knowledge base stays coherent — not just code-vs-docs.",
  },
  {
    title: "Owned & accountable",
    body: "Pegs a human or team — and a DRI — to every doc. When an owner departs, the doc is flagged as an orphan until it's reassigned.",
  },
  {
    title: "Review SLAs",
    body: "Every doc carries a last-reviewed date and an audience-scoped SLA. Custodex surfaces what's stale or never reviewed before it rots.",
  },
  {
    title: "Fix or invalidate",
    body: "On real drift, a pluggable LLM backend proposes a fix or invalidates the change — and records the original drift plus the proposal as an auditable ReviewRecord. Auto-apply is opt-in.",
  },
  {
    title: "Governs many repos",
    body: "A central server clones repos on demand, opens docs-PRs, and tracks coverage, ownership, and staleness across a whole fleet from one console.",
  },
];
---

<div class="lp">
  <header class="lp-nav">
    <a class="lp-brand" href="/">
      <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect x="1" y="1" width="30" height="30" rx="7" stroke="var(--accent)" stroke-opacity="0.4" stroke-width="1.4"></rect>
        <path d="M7 11c5 0 5 4 9 4M7 21c5 0 5-4 9-4" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round"></path>
        <circle cx="22.5" cy="15" r="3.2" fill="var(--sync)"></circle>
        <circle cx="22.5" cy="15" r="6" stroke="var(--sync)" stroke-opacity="0.3" stroke-width="1.2"></circle>
      </svg>
      <span>Custodex</span>
    </a>
    <nav class="lp-nav__links" aria-label="primary">
      <a href="/demo">Live demo</a>
      <a href="/wiki/features">Wiki</a>
      <a href="/tutorial">Tutorial</a>
      <a href={REPO} target="_blank" rel="noreferrer">GitHub ↗</a>
    </nav>
  </header>

  <section class="lp-hero">
    <p class="lp-eyebrow">custodian + codex</p>
    <h1>Keep your code and docs<br /><span>in sync, owned, and accountable.</span></h1>
    <p class="lp-sub">
      Custodex catches drift across <strong>code↔doc and doc↔doc</strong>, pegs an
      <strong>owner</strong> to every doc, tracks <strong>review SLAs</strong>, and —
      when something drifts — fixes, invalidates, or escalates it, recording every
      verdict for human review. The custodian of your documentation: it keeps the
      record straight, and keeps someone answerable for it.
    </p>
    <div class="lp-cta">
      <a class="lp-btn lp-btn--primary" href="/demo">Try the live demo →</a>
      <a class="lp-btn" href="/tutorial">Get started</a>
      <a class="lp-btn lp-btn--ghost" href={REPO} target="_blank" rel="noreferrer">View on GitHub</a>
    </div>
    <pre class="lp-snippet" aria-label="quickstart"><code>pip install custodex
cdx check     <span class="lp-comment"># detect drift (code↔doc &amp; doc↔doc)</span>
cdx monitor   <span class="lp-comment"># fix / invalidate, log a ReviewRecord</span>
cdx ownership <span class="lp-comment"># who owns what — and what's orphaned</span>
cdx staleness <span class="lp-comment"># what's past its review SLA</span></code></pre>
  </section>

  <section class="lp-features" aria-label="capabilities">
    {
      FEATURES.map((f) => (
        <article class="lp-card">
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </article>
      ))
    }
  </section>

  <section class="lp-strip">
    <div>
      <h2>See it without installing anything.</h2>
      <p>The <a href="/demo">live demo</a> is the real Custodex console running on a baked sample dataset — click through the fleet, ownership, staleness, and coverage. Then browse the <a href="/wiki/features">feature wiki</a> or follow the <a href="/tutorial">tutorial</a> to adopt it.</p>
    </div>
    <a class="lp-btn lp-btn--primary" href="/demo">Open the demo →</a>
  </section>

  <footer class="lp-foot">
    <span>Custodex · <code>cdx</code></span>
    <span><a href={REPO} target="_blank" rel="noreferrer">github.com/JuanSync7/custodex</a></span>
  </footer>
</div>

<style>
  .lp {
    min-height: 100vh;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-sans, system-ui, sans-serif);
  }
  .lp-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1040px;
    margin: 0 auto;
    padding: 1.1rem 1.5rem;
  }
  .lp-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--ink);
    text-decoration: none;
  }
  .lp-brand svg {
    width: 28px;
    height: 28px;
  }
  .lp-nav__links {
    display: flex;
    gap: 1.4rem;
    font-size: 0.92rem;
  }
  .lp-nav__links a {
    color: var(--muted, #5b6472);
    text-decoration: none;
  }
  .lp-nav__links a:hover {
    color: var(--ink);
  }
  .lp-hero {
    max-width: 820px;
    margin: 0 auto;
    padding: 3.4rem 1.5rem 1rem;
    text-align: center;
  }
  .lp-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 0.9rem;
  }
  .lp-hero h1 {
    font-size: clamp(2rem, 5vw, 3.1rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.1rem;
  }
  .lp-hero h1 span {
    color: var(--accent);
  }
  .lp-sub {
    font-size: 1.06rem;
    line-height: 1.6;
    color: var(--muted, #5b6472);
    max-width: 660px;
    margin: 0 auto 1.8rem;
  }
  .lp-cta {
    display: flex;
    gap: 0.7rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.2rem;
  }
  .lp-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.62rem 1.15rem;
    border-radius: var(--radius);
    border: 1px solid var(--line-strong);
    background: var(--panel);
    color: var(--ink);
    font-weight: 600;
    font-size: 0.94rem;
    text-decoration: none;
  }
  .lp-btn:hover {
    border-color: var(--accent);
  }
  .lp-btn--primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .lp-btn--primary:hover {
    background: var(--accent-strong);
  }
  .lp-btn--ghost {
    background: transparent;
  }
  .lp-snippet {
    text-align: left;
    max-width: 560px;
    margin: 0 auto;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 1rem 1.2rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.86rem;
    line-height: 1.7;
    color: var(--ink);
    overflow-x: auto;
  }
  .lp-comment {
    color: var(--muted, #8a93a3);
  }
  .lp-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    max-width: 1040px;
    margin: 2.6rem auto;
    padding: 0 1.5rem;
  }
  .lp-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 1.3rem;
  }
  .lp-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.02rem;
  }
  .lp-card p {
    margin: 0;
    color: var(--muted, #5b6472);
    font-size: 0.93rem;
    line-height: 1.55;
  }
  .lp-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    max-width: 1040px;
    margin: 0 auto 3rem;
    padding: 1.8rem;
    background: var(--accent-tint);
    border: 1px solid var(--accent);
    border-radius: var(--radius-lg);
  }
  .lp-strip h2 {
    margin: 0 0 0.4rem;
    font-size: 1.25rem;
  }
  .lp-strip p {
    margin: 0;
    color: var(--ink);
    font-size: 0.96rem;
    max-width: 640px;
  }
  .lp-strip a {
    color: var(--accent-strong);
  }
  .lp-foot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    max-width: 1040px;
    margin: 0 auto;
    padding: 1.5rem;
    border-top: 1px solid var(--line);
    color: var(--muted, #5b6472);
    font-size: 0.86rem;
  }
  .lp-foot a {
    color: var(--muted, #5b6472);
  }
</style>
