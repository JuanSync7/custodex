---
// Static replica of the console's AppShell chrome (the top COMMAND BAR), for the
// native-Astro pages (the wiki) so they share the SAME navigation as the main
// console. Reuses the console's own CSS classes (imported below), so it is
// pixel-identical; nav items are REAL links (the console is a separate SPA,
// reached via `/` and `/#/...`). The live connection pill is the one React island.
import "../console/index.css";
import ConnectionStatus from "../console/components/ConnectionStatus.tsx";

interface Props {
  /** Which top-bar item is active on this page. */
  active?: "fleet" | "wiki";
  /** The page label (names the main landmark). */
  crumb: string;
}
const { active, crumb } = Astro.props;
const link = (on: boolean) => `topnav__link${on ? " topnav__link--active" : ""}`;
---

<div class="app">
  <header class="topnav">
    <a class="topnav__brand" href="/" aria-label="code-doc-monitor console">
      <svg class="topnav__brandmark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect x="1" y="1" width="30" height="30" rx="7" stroke="var(--accent)" stroke-opacity="0.4" stroke-width="1.4"></rect>
        <path d="M7 11c5 0 5 4 9 4M7 21c5 0 5-4 9-4" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round"></path>
        <circle cx="22.5" cy="15" r="3.2" fill="var(--sync)"></circle>
        <circle cx="22.5" cy="15" r="6" stroke="var(--sync)" stroke-opacity="0.3" stroke-width="1.2"></circle>
      </svg>
      <span class="topnav__word">
        <span class="topnav__title">drift console</span>
        <span class="topnav__sub">code · doc · monitor</span>
      </span>
    </a>

    <nav class="topnav__nav" aria-label="primary">
      <a class={link(active === "fleet")} href="/">
        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3 3 7.5 12 12l9-4.5L12 3Z"></path><path d="M3 12l9 4.5L21 12"></path><path d="M3 16.5 12 21l9-4.5"></path>
        </svg>
        Fleet
      </a>
      <a class="topnav__link" href="/#/config">
        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z"></path><path d="M14 3v5h5"></path><path d="m9 14 2 2 3-4"></path>
        </svg>
        Format
      </a>
      <a class={link(active === "wiki")} href="/wiki/features">
        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z"></path><path d="M14 3v5h5"></path><path d="m9 14 2 2 3-4"></path>
        </svg>
        Wiki
      </a>
    </nav>

    <div class="topnav__spacer"></div>

    <nav class="topnav__nav topnav__nav--ref" aria-label="reference">
      <a class="topnav__link" href="/docs" target="_blank" rel="noreferrer">
        API Docs
        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:13px;height:13px">
          <path d="M14 4h6v6"></path><path d="M20 4 11 13"></path><path d="M18 14v4a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4"></path>
        </svg>
      </a>
      <a class="topnav__link" href="/openapi.json" target="_blank" rel="noreferrer">
        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12h4l2-6 4 12 2-6h6"></path>
        </svg>
        OpenAPI
      </a>
    </nav>

    <span class="topnav__div"></span>
    <ConnectionStatus client:load />
  </header>

  <main class="canvas" aria-label={crumb}>
    <slot />
  </main>
</div>
