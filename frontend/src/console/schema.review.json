{
  "$defs": {
    "Audience": {
      "description": "Who a document is written for \u2014 drives extraction and drift verdicts.",
      "enum": [
        "user-guide",
        "eng-guide"
      ],
      "title": "Audience",
      "type": "string"
    },
    "ProposedFix": {
      "additionalProperties": false,
      "description": "A backend-proposed remediation for one drift.\n\nEither a region-shaped fix (``region_id`` + ``new_region_body``) or a\nwhole-doc fix (``new_doc_text``); ``rationale`` always explains the choice.\nSatisfies the structural ``heal.ProposedFixLike`` Protocol.",
      "properties": {
        "new_doc_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "New Doc Text"
        },
        "new_region_body": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "New Region Body"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "region_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region Id"
        }
      },
      "required": [
        "rationale"
      ],
      "title": "ProposedFix",
      "type": "object"
    },
    "Verdict": {
      "description": "The backend's decision for one drift (mirrors SPEC *Verdict*).",
      "enum": [
        "FIX",
        "INVALIDATE",
        "ESCALATE"
      ],
      "title": "Verdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "The public, versioned payload for one handled drift (K5, K6).\n\nCarries BOTH the original drift (``drift_kind``/``drift_detail``) and the\nproposed ``fix`` so a human can review what changed and why (K5). Timestamps\nare injected ISO strings, never read from the clock here (K10).",
  "properties": {
    "audience": {
      "$ref": "#/$defs/Audience"
    },
    "backend_kind": {
      "title": "Backend Kind",
      "type": "string"
    },
    "cause": {
      "title": "Cause",
      "type": "string"
    },
    "config_snapshot": {
      "additionalProperties": true,
      "title": "Config Snapshot",
      "type": "object"
    },
    "detected_at": {
      "title": "Detected At",
      "type": "string"
    },
    "doc_id": {
      "title": "Doc Id",
      "type": "string"
    },
    "doc_path": {
      "title": "Doc Path",
      "type": "string"
    },
    "drift_detail": {
      "title": "Drift Detail",
      "type": "string"
    },
    "drift_kind": {
      "title": "Drift Kind",
      "type": "string"
    },
    "fix": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProposedFix"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "record_id": {
      "title": "Record Id",
      "type": "string"
    },
    "resolved_at": {
      "title": "Resolved At",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Sha"
    },
    "surface_hash": {
      "title": "Surface Hash",
      "type": "string"
    },
    "verdict": {
      "$ref": "#/$defs/Verdict"
    }
  },
  "required": [
    "record_id",
    "doc_id",
    "doc_path",
    "audience",
    "drift_kind",
    "drift_detail",
    "cause",
    "verdict",
    "surface_hash",
    "backend_kind",
    "detected_at",
    "resolved_at",
    "config_snapshot"
  ],
  "title": "ReviewRecord",
  "type": "object"
}
