{
  "$defs": {
    "AcceptanceCheck": {
      "additionalProperties": false,
      "description": "One acceptance-criterion line a reviewer confirms (K8 immutable).\n\n``auto_satisfied`` is the agent's CLAIM that the proposed change already\nmeets this criterion; the human still confirms it.",
      "properties": {
        "auto_satisfied": {
          "default": false,
          "title": "Auto Satisfied",
          "type": "boolean"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "AcceptanceCheck",
      "type": "object"
    },
    "Audience": {
      "description": "Who a document is written for \u2014 drives extraction and drift verdicts.",
      "enum": [
        "user-guide",
        "eng-guide"
      ],
      "title": "Audience",
      "type": "string"
    },
    "DriftTicket": {
      "additionalProperties": false,
      "description": "The structured, human-validatable artifact for one handled drift (K6).\n\nFrozen + ``extra=\"forbid\"``: an immutable audited artifact (K8). Built\ndeterministically from the drift/verdict/cause/fix/surface (K10), never from\na clock or I/O. Carries a ``schema_version`` and is emitted from the model.",
      "properties": {
        "acceptance_criteria": {
          "default": [],
          "items": {
            "$ref": "#/$defs/AcceptanceCheck"
          },
          "title": "Acceptance Criteria",
          "type": "array"
        },
        "affected_symbols": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Affected Symbols",
          "type": "array"
        },
        "audience": {
          "title": "Audience",
          "type": "string"
        },
        "change_kind": {
          "title": "Change Kind",
          "type": "string"
        },
        "diff": {
          "default": "",
          "title": "Diff",
          "type": "string"
        },
        "doc_id": {
          "title": "Doc Id",
          "type": "string"
        },
        "doc_path": {
          "title": "Doc Path",
          "type": "string"
        },
        "drift_kind": {
          "title": "Drift Kind",
          "type": "string"
        },
        "proposed_change": {
          "title": "Proposed Change",
          "type": "string"
        },
        "recommended_action": {
          "title": "Recommended Action",
          "type": "string"
        },
        "region_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region Id"
        },
        "root_cause": {
          "title": "Root Cause",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/TicketSeverity"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "ticket_id": {
          "title": "Ticket Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "verdict": {
          "title": "Verdict",
          "type": "string"
        }
      },
      "required": [
        "ticket_id",
        "title",
        "summary",
        "severity",
        "drift_kind",
        "doc_id",
        "doc_path",
        "audience",
        "root_cause",
        "proposed_change",
        "change_kind",
        "verdict",
        "recommended_action"
      ],
      "title": "DriftTicket",
      "type": "object"
    },
    "ProposedFix": {
      "additionalProperties": false,
      "description": "A backend-proposed remediation for one drift.\n\nEither a region-shaped fix (``region_id`` + ``new_region_body``) or a\nwhole-doc fix (``new_doc_text``); ``rationale`` always explains the choice.\nSatisfies the structural ``heal.ProposedFixLike`` Protocol.",
      "properties": {
        "new_doc_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "New Doc Text"
        },
        "new_region_body": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "New Region Body"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "region_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region Id"
        }
      },
      "required": [
        "rationale"
      ],
      "title": "ProposedFix",
      "type": "object"
    },
    "TicketSeverity": {
      "description": "How urgently a human should look at a drift ticket.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "TicketSeverity",
      "type": "string"
    },
    "Verdict": {
      "description": "The backend's decision for one drift (mirrors SPEC *Verdict*).",
      "enum": [
        "FIX",
        "INVALIDATE",
        "ESCALATE"
      ],
      "title": "Verdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "The public, versioned payload for one handled drift (K5, K6).\n\nCarries BOTH the original drift (``drift_kind``/``drift_detail``) and the\nproposed ``fix`` so a human can review what changed and why (K5). Timestamps\nare injected ISO strings, never read from the clock here (K10).",
  "properties": {
    "audience": {
      "$ref": "#/$defs/Audience"
    },
    "backend_kind": {
      "title": "Backend Kind",
      "type": "string"
    },
    "cause": {
      "title": "Cause",
      "type": "string"
    },
    "change_severity": {
      "default": "unknown",
      "title": "Change Severity",
      "type": "string"
    },
    "config_snapshot": {
      "additionalProperties": true,
      "title": "Config Snapshot",
      "type": "object"
    },
    "detected_at": {
      "title": "Detected At",
      "type": "string"
    },
    "doc_id": {
      "title": "Doc Id",
      "type": "string"
    },
    "doc_path": {
      "title": "Doc Path",
      "type": "string"
    },
    "drift_detail": {
      "title": "Drift Detail",
      "type": "string"
    },
    "drift_kind": {
      "title": "Drift Kind",
      "type": "string"
    },
    "drifted_tiers": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Drifted Tiers",
      "type": "array"
    },
    "fix": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProposedFix"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "record_id": {
      "title": "Record Id",
      "type": "string"
    },
    "resolved_at": {
      "title": "Resolved At",
      "type": "string"
    },
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Sha"
    },
    "surface_hash": {
      "title": "Surface Hash",
      "type": "string"
    },
    "ticket": {
      "anyOf": [
        {
          "$ref": "#/$defs/DriftTicket"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "verdict": {
      "$ref": "#/$defs/Verdict"
    }
  },
  "required": [
    "record_id",
    "doc_id",
    "doc_path",
    "audience",
    "drift_kind",
    "drift_detail",
    "cause",
    "verdict",
    "surface_hash",
    "backend_kind",
    "detected_at",
    "resolved_at",
    "config_snapshot"
  ],
  "title": "ReviewRecord",
  "type": "object"
}
