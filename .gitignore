# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# cdx runtime output (the local review log is generated, not source)
.cdmon/

# Generated HTML twins (produced by `cdx build`; derived-not-edited)
docs/**/*.html

# frontend/ (EPIC ASTRO) Astro app build artifacts / deps. package-lock.json IS
# committed; `frontend/dist/` is the served build, `.astro/` is generated types.
frontend/node_modules/
frontend/dist/
frontend/.astro/

# Local agent / tooling state — per-developer runtime, never shared
.claude/
.playwright-mcp/

# One-off screenshots / scratch captures at repo root (verification artifacts,
# never tracked source assets). Root-anchored so it can't shadow images that
# legitimately live in subdirs (docs/, feature-doc/, …).
/*.png
