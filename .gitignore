# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# cdmon runtime output (the local review log is generated, not source)
.cdmon/

# Generated HTML twins (produced by `cdmon build`; derived-not-edited)
docs/**/*.html

# frontend/ (EPIC ASTRO) Astro app build artifacts / deps. package-lock.json IS
# committed; `frontend/dist/` is the served build, `.astro/` is generated types.
frontend/node_modules/
frontend/dist/
frontend/.astro/

# Local agent / tooling state — per-developer runtime, never shared
.claude/
.playwright-mcp/

# One-off screenshots / scratch captures (not tracked source assets)
/cdmon-fleet.png
